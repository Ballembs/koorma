# ─── Supabase (Auth & Progress Tracking) ───
# Get these from: Supabase Dashboard → Settings → API Keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_your-key-here

# ─── Google AI (Gemini content generation) ───
# Get from: Google AI Studio → API Keys
GEMINI_API_KEY=your-gemini-api-key-here

# ─── Google Cloud (TTS & STT) ───
# Download JSON from: Google Cloud Console → IAM → Service Accounts → Keys
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
